{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "NewsItem": {
      "title": "News Item",
      "description": "A processed or generated news result",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "originalHeadline": { "type": "string" },
        "formattedHeadline": { "type": "string" },
        "spot": { "type": "string" },
        "subheadings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "mode": { "type": "string", "enum": ["meta", "full", "generated"] }
      },
      "required": ["id", "formattedHeadline", "spot", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/history_changed/{itemId}": {
      "schema": "NewsItem",
      "description": "News items that were changed/processed"
    },
    "/users/{userId}/history_generated/{itemId}": {
      "schema": "NewsItem",
      "description": "News items that were generated from scratch"
    }
  }
}
