rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string 
        && data.keys().hasAll(['uid', 'email'])
        && (data.get('newsCounter', 0) is int)
        && data.keys().size() <= 8;
    }

    function isValidNewsItem(data) {
      return data.id is string && data.id.size() <= 128
        && data.formattedHeadline is string && data.formattedHeadline.size() <= 500
        && data.spot is string && data.spot.size() <= 1000
        && data.content is string && data.content.size() <= 20000
        && data.createdAt == request.time
        && data.keys().hasAll(['id', 'formattedHeadline', 'spot', 'content', 'createdAt'])
        && data.keys().size() <= 10;
    }

    // --- Routes ---
    
    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
      
      // History Subcollections
      match /history_changed/{itemId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(itemId) && isValidNewsItem(incoming());
        allow update, delete: if isOwner(userId); // Owners can manage their history
      }

      match /history_generated/{itemId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(itemId) && isValidNewsItem(incoming());
        allow update, delete: if isOwner(userId);
      }
    }
  }
}
